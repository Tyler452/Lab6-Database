<%- include('partials/head', { title: 'Lab 6 Quote Finder' }) %>
<div class="page-container">
    <div class="hero-banner">
        <p class="hero-kicker">Lab 6 Database Search</p>
        <h1 class="page-title mb-3">Find quotes by keyword, author, category, or likes.</h1>
        <p class="hero-copy mb-0">Every search option is wired to the database, and author details open inline without leaving the page.</p>
    </div>

    <div class="search-grid">
        <form action="/searchByKeyword" method="GET" class="search-form search-card" id="keywordForm" novalidate>
            <label for="keyword" class="search-label">Keyword</label>
            <p class="search-copy">Search the quote text. Minimum 3 characters.</p>
            <input
                type="text"
                name="keyword"
                id="keyword"
                class="form-control"
                placeholder="e.g. hope"
                value="<%= formValues.keyword %>"
                aria-describedby="keywordError"
            >
            <p id="keywordError" class="form-error <%= keywordError ? 'is-visible' : '' %>"><%= keywordError || '' %></p>
            <button class="btn btn-primary action-button" id="search">Search By Keyword</button>
        </form>

        <form action="/searchByAuthor" method="GET" class="search-form search-card">
            <label for="author" class="search-label">Author</label>
            <p class="search-copy">Author names are loaded directly from the database.</p>
            <select name="authorId" id="author" class="form-control">
                <% for(let author of authors) { %>
                    <option value="<%= author.authorId %>" <%= String(formValues.authorId) === String(author.authorId) ? 'selected' : '' %>><%= author.firstName %> <%= author.lastName %></option>
                <% } %>
            </select>
            <button class="btn btn-secondary action-button" id="searchByAuthor">Search By Author</button>
        </form>

        <form action="/searchByCategory" method="GET" class="search-form search-card">
            <label for="category" class="search-label">Category</label>
            <p class="search-copy">Category choices also come from the database.</p>
            <select name="category" id="category" class="form-control">
                <% for(let category of categories) { %>
                    <option value="<%= category.category %>" <%= formValues.category === category.category ? 'selected' : '' %>><%= category.category %></option>
                <% } %>
            </select>
            <button class="btn btn-dark action-button" id="searchByCategory">Search By Category</button>
        </form>

        <form action="/searchByLikes" method="GET" class="search-form search-card">
            <label for="minLikes" class="search-label">Likes Range</label>
            <p class="search-copy">Set a minimum and maximum likes count.</p>
            <div class="likes-range-inputs">
                <input type="number" name="minLikes" id="minLikes" class="form-control" placeholder="Min" min="0" value="<%= formValues.minLikes %>">
                <input type="number" name="maxLikes" id="maxLikes" class="form-control" placeholder="Max" min="0" value="<%= formValues.maxLikes %>">
            </div>
            <button class="btn btn-info text-white action-button" id="searchByLikes">Search By Likes</button>
        </form>
    </div>
</div>
<script src="/js/home.js"></script>
<%- include('partials/footer') %>